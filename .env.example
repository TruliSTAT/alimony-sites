# ============================================================
# Alimony Sites — Environment Variables
# Copy this to .env.local and fill in values
# ============================================================

# Brand switch: "noalimony" | "knowalimony"
NEXT_PUBLIC_BRAND=noalimony

# Site URLs
NEXT_PUBLIC_SITE_URL=https://noalimony.com

# Database (SQLite path — relative to project root)
DB_PATH=./data/alimony.db

# Auth secret for JWT signing (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-secure-random-string-in-production

# Admin seed credentials (used by seed script)
ADMIN_EMAIL=admin@noalimony.com
ADMIN_PASSWORD=changeme123

# Email routing (optional — for lead forwarding)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=leads@noalimony.com

# IP Geolocation (ipapi.co — free tier, 1000 req/day)
# Leave blank to use free tier (no key required)
IPAPI_KEY=

# Plausible Analytics (privacy-friendly, no cookies)
# Set to your site domain: noalimony.com or knowalimony.com
PLAUSIBLE_DOMAIN=noalimony.com
